# In development, leave VITE_API_URL unset.
# Vite proxies /api/* → http://localhost:5001 (see vite.config.js).
# Set this only for production builds pointing at a deployed backend.
# VITE_API_URL=https://your-backend.com/api

# Google Maps JavaScript API key (enable Maps JS API + Geocoding API in Cloud Console)
VITE_GOOGLE_MAPS_KEY=YOUR_KEY_HERE
