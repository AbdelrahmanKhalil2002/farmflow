# ─── Server ───────────────────────────────────────────────────────────────────
# Render injects PORT automatically — do not set this in Render's environment.
PORT=5001

# ─── Database ─────────────────────────────────────────────────────────────────
# Development: local MongoDB
# MONGO_URI=mongodb://localhost:27017/farmflow
#
# Production: MongoDB Atlas connection string
# Replace <username>, <password>, and <cluster> with your Atlas credentials.
# Ensure the Atlas cluster allows connections from 0.0.0.0/0 (or Render's IPs).
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/farmflow?retryWrites=true&w=majority

# ─── Authentication ───────────────────────────────────────────────────────────
# Use a cryptographically random 256-bit value in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ─── Environment ──────────────────────────────────────────────────────────────
NODE_ENV=production

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Set to your Vercel frontend URL (no trailing slash).
# In development: http://localhost:5173
FRONTEND_URL=https://your-app.vercel.app

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Required for: password reset, email verification, admin 2FA, order notifications.
# Leave blank to disable email (features degrade gracefully — no emails sent).
# Gmail example: use an App Password (not your main password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="FarmFlow <your-email@gmail.com>"
