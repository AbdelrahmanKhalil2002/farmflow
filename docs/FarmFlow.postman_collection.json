        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            },
            "description": "Returns the profile of the user whose token is in {{token}}. Returns 403 if the account is deactivated."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('Has _id', () => pm.expect(pm.response.json()._id).to.be.a('string'));",
                  "pm.test('Password not in response', () => pm.expect(pm.response.json().password).to.be.undefined);"
                ]
              }
            }
          ],
          "response": []
        }

      ]
    },

    {
      "name": "Listings",
      "description": "CRUD for livestock listings. GET endpoints support optional auth; POST/PUT/DELETE require seller or admin.",
      "item": [

        {
          "name": "Browse — Public (no token)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/listings",
              "host": ["{{base_url}}"],
              "path": ["listings"]
            },
            "description": "Returns only approved listings. No token required. Same endpoint used by buyers."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('Response is array', () => pm.expect(pm.response.json()).to.be.an('array'));",
                  "const listings = pm.response.json();",
                  "if (listings.length > 0) {",
                  "    pm.test('All listings are approved', () => {",
                  "        listings.forEach(l => pm.expect(l.status).to.eql('approved'));",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },

        {
          "name": "Browse — Role-Scoped (uses {{token}})",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/listings",
              "host": ["{{base_url}}"],
              "path": ["listings"]
            },
            "description": "Returns listings filtered by the caller's role:\n- seller  → only their own listings (all statuses)\n- buyer   → approved only\n- admin   → all listings (all statuses)"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('Response is array', () => pm.expect(pm.response.json()).to.be.an('array'));",
                  "const listings = pm.response.json();",
                  "if (listings.length > 0) {",
                  "    pm.environment.set('listing_id', listings[0]._id);",
                  "    console.log('listing_id set to: ' + listings[0]._id);",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },

        {
          "name": "Get Listing by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/listings/{{listing_id}}",
              "host": ["{{base_url}}"],
              "path": ["listings", "{{listing_id}}"]
            },
            "description": "Returns a single listing. Access is role-scoped: buyers only see approved listings, sellers only see their own."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('Has seller populated', () => pm.expect(pm.response.json().seller).to.be.an('object'));"
                ]
              }
            }
          ],
          "response": []
        },

        {
          "name": "Create Listing (Seller)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "type",        "value": "sheep",                    "type": "text" },
                { "key": "breed",       "value": "Najdi",                    "type": "text" },
                { "key": "age",         "value": "18",                       "type": "text" },
                { "key": "weight",      "value": "45",                       "type": "text" },
                { "key": "price",       "value": "1500",                     "type": "text" },
                { "key": "location",    "value": "Riyadh",                   "type": "text" },
                { "key": "description", "value": "Healthy sheep, vaccinated.", "type": "text" },
                { "key": "images",      "type": "file", "src": [], "disabled": true }
              ]
            },
            "url": {
              "raw": "{{base_url}}/listings",
              "host": ["{{base_url}}"],
              "path": ["listings"]
            },
            "description": "Create a new listing. Requires seller token in {{token}}.\n\nSends multipart/form-data. To attach images, enable the 'images' row and select files.\n\nStatus defaults to 'pending' — admin must approve before it appears to buyers.\n\nTest script saves the new listing's _id to {{listing_id}}."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', () => pm.expect(pm.response.code).to.eql(201));",
                  "const res = pm.response.json();",
                  "pm.test('Status is pending', () => pm.expect(res.status).to.eql('pending'));",
                  "pm.test('Listing ID present', () => pm.expect(res._id).to.be.a('string'));",
                  "pm.environment.set('listing_id', res._id);",
                  "console.log('listing_id saved: ' + res._id);"
                ]
              }
            }
          ],
          "response": []
        },

        {
          "name": "Approve Listing (Admin)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"approved\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/listings/{{listing_id}}",
              "host": ["{{base_url}}"],
              "path": ["listings", "{{listing_id}}"]
            },
            "description": "Approve a pending listing. Requires admin token in {{token}}.\n\nAfter approval the listing becomes visible to all buyers."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('Listing status is approved', () => pm.expect(pm.response.json().status).to.eql('approved'));"
                ]
              }
            }
          ],
          "response": []
        },

        {
          "name": "Reject Listing (Admin)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"rejected\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/listings/{{listing_id}}",
              "host": ["{{base_url}}"],
              "path": ["listings", "{{listing_id}}"]
            },
            "description": "Reject a listing. Requires admin token in {{token}}."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('Listing status is rejected', () => pm.expect(pm.response.json().status).to.eql('rejected'));"
                ]
              }
            }
          ],
          "response": []
        },

        {
          "name": "Update Listing (Seller)",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "price",       "value": "1800", "type": "text" },
                { "key": "description", "value": "Price updated. Still available.", "type": "text" },
                { "key": "images",      "type": "file", "src": [], "disabled": true }
              ]
            },
            "url": {
              "raw": "{{base_url}}/listings/{{listing_id}}",
              "host": ["{{base_url}}"],
              "path": ["listings", "{{listing_id}}"]
            },
            "description": "Update listing content fields. Requires seller token in {{token}}.\n\nSellers cannot change status — only admin can.\nNew images are appended (not replaced)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.expect(pm.response.code).to.eql(200));"
                ]
              }
            }
          ],
          "response": []
        },

        {
          "name": "Delete Listing",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/listings/{{listing_id}}",
              "host": ["{{base_url}}"],
              "path": ["listings", "{{listing_id}}"]
            },
            "description": "Permanently delete a listing. Seller can only delete their own. Admin can delete any."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 204', () => pm.expect(pm.response.code).to.eql(204));"
                ]
              }
            }
          ],
          "response": []
        }

      ]
    },

    {
      "name": "Orders",
      "description": "Place and manage purchase orders. Role-based scoping: buyers place orders, sellers confirm/complete, admin can set any status.",
      "item": [

        {
          "name": "Place Order (Buyer)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"listingId\": \"{{listing_id}}\",\n  \"paymentType\": \"deposit\",\n  \"depositAmount\": 300,\n  \"notes\": \"Please deliver to Riyadh.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/orders",
              "host": ["{{base_url}}"],
              "path": ["orders"]
            },
            "description": "Place an order on an approved listing. Requires buyer token in {{token}}.\n\nFor COD payment, remove depositAmount and set paymentType to 'cod'.\nFor deposit: depositAmount must be > 0 and < listing price.\n\nTest script saves the new order _id to {{order_id}}."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', () => pm.expect(pm.response.code).to.eql(201));",
                  "const res = pm.response.json();",
                  "pm.test('Order status is pending', () => pm.expect(res.status).to.eql('pending'));",
                  "pm.test('Order ID present', () => pm.expect(res._id).to.be.a('string'));",
                  "pm.environment.set('order_id', res._id);",
                  "console.log('order_id saved: ' + res._id);"
                ]
              }
            }
          ],
          "response": []
        },

        {
          "name": "Place Order — COD",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"listingId\": \"{{listing_id}}\",\n  \"paymentType\": \"cod\",\n  \"notes\": \"I will pick it up from the farm.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/orders",
              "host": ["{{base_url}}"],
              "path": ["orders"]
            },
            "description": "Place a cash-on-delivery order. Requires buyer token in {{token}}."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', () => pm.expect(pm.response.code).to.eql(201));",
                  "const res = pm.response.json();",
                  "pm.test('Payment type is cod', () => pm.expect(res.paymentType).to.eql('cod'));",
                  "pm.environment.set('order_id', res._id);",
                  "console.log('order_id saved: ' + res._id);"
                ]
              }
            }
          ],
          "response": []
        },

        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/orders",
              "host": ["{{base_url}}"],
              "path": ["orders"]
            },
            "description": "Returns orders scoped to caller's role:\n- buyer  → their own orders\n- seller → orders on their listings\n- admin  → all orders"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('Response is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ],
          "response": []
        },

        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/orders/{{order_id}}",
              "host": ["{{base_url}}"],
              "path": ["orders", "{{order_id}}"]
            },
            "description": "Get a specific order. Buyer sees own orders; seller sees orders on their listings; admin sees all."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('Has listing populated', () => pm.expect(pm.response.json().listing).to.be.an('object'));"
                ]
              }
            }
          ],
          "response": []
        },

        {
          "name": "Confirm Order (Seller)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"confirmed\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/orders/{{order_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["orders", "{{order_id}}", "status"]
            },
            "description": "Seller confirms a pending order. Requires seller token in {{token}}.\n\nValid transitions for seller:\n  pending   → confirmed | cancelled\n  confirmed → completed | cancelled"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('Order status is confirmed', () => pm.expect(pm.response.json().status).to.eql('confirmed'));"
                ]
              }
            }
          ],
          "response": []
        },

        {
          "name": "Complete Order (Seller)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"completed\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
