{
  "info": {
    "_postman_id": "farmflow-api-collection-v1",
    "name": "FarmFlow API",
    "description": "Complete API collection for FarmFlow — livestock marketplace.\n\nSetup:\n1. Import FarmFlow.postman_environment.json alongside this collection.\n2. Select the 'FarmFlow — Local' environment.\n3. Run 'Login — Seller', 'Login — Buyer', or 'Login — Admin' first.\n   Each login auto-saves its token to the environment.\n4. All protected requests use {{token}} automatically via the collection-level Bearer auth.\n\nToken variables:\n  {{token}}        — active token (overwritten by each login request)\n  {{seller_token}} — saved by 'Login — Seller'\n  {{buyer_token}}  — saved by 'Login — Buyer'\n  {{admin_token}}  — saved by 'Login — Admin'\n\nID variables (auto-saved by test scripts):\n  {{listing_id}}   — saved after 'Create Listing'\n  {{order_id}}     — saved after 'Place Order'\n  {{user_id}}      — saved after 'Get All Users' (first non-admin user)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [

    {
      "name": "Auth",
      "description": "Registration, login, and profile endpoints. Login requests auto-save tokens to environment variables.",
      "item": [

        {
          "name": "Register — Seller",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ahmed Ali\",\n  \"email\": \"seller@farmflow.com\",\n  \"password\": \"seller123\",\n  \"role\": \"seller\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            },
            "description": "Register a new seller account. Returns a JWT and user object. Test script auto-saves the token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status is 201', () => pm.expect(pm.response.code).to.eql(201));",
                  "pm.test('Response has token', () => pm.expect(res.token).to.be.a('string'));",
                  "pm.test('Role is seller', () => pm.expect(res.user.role).to.eql('seller'));",
                  "if (res.token) {",
                  "    pm.environment.set('token', res.token);",
                  "    pm.environment.set('seller_token', res.token);",
                  "    console.log('Seller token saved.');",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },

        {
          "name": "Register — Buyer",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sara Hassan\",\n  \"email\": \"buyer@farmflow.com\",\n  \"password\": \"buyer123\",\n  \"role\": \"buyer\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            },
            "description": "Register a new buyer account."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
