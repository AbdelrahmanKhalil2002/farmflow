              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status is 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('Role is admin', () => pm.expect(res.user.role).to.eql('admin'));",
                  "if (res.token) {",
                  "    pm.environment.set('token', res.token);",
