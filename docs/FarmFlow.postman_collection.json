                  "pm.test('Status is 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('Response is array', () => pm.expect(pm.response.json()).to.be.an('array'));",
                  "const users = pm.response.json();",
                  "const target = users.find(u => u.role !== 'admin');",
                  "if (target) {",
                  "    pm.environment.set('user_id', target._id);",
                  "    console.log('user_id set to: ' + target._id + ' (' + target.role + ')');",
                  "} else {",
                  "    console.warn('No non-admin users found to set user_id.');",
                  "}"
                ]
