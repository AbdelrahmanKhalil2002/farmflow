                  "pm.test('Role is buyer', () => pm.expect(res.user.role).to.eql('buyer'));",
                  "if (res.token) {",
                  "    pm.environment.set('token', res.token);",
                  "    pm.environment.set('buyer_token', res.token);",
                  "    console.log('Buyer token saved.');",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },

